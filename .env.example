# Gemini API Key (Required for code generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Git settings (Optional, defaults to the current repo)
# TARGET_REPO_PATH=/path/to/your/leetcode/repo
# DEFAULT_BRANCH=main

# Default programming language (e.g., python3, cpp, java, javascript)
DEFAULT_LANGUAGE=python3

# GitHub API Push configurations (Required if system git is not installed / preferred)
# GITHUB_TOKEN=your_github_personal_access_token
# GITHUB_REPOSITORY=your_username/your_repo_name

